{
  "expo": {
    "name": "Lotto Lucky Number Helper",
    "slug": "lotto-helper-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08111f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.damifan.lottohelper"
    },
    "android": {
      "package": "com.damifan.lottohelper",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08111f"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "https://lotto-lucky888.vercel.app/api"
    }
  }
}
