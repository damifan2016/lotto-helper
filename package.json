{
  "name": "lotto-helper",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @lotto/api",
    "dev:web": "npm run dev -w @lotto/web",
    "dev:mobile": "npm run start -w @lotto/mobile",
    "dev:android": "npm run android -w @lotto/mobile",
    "build:android": "npm run build:android -w @lotto/mobile",
    "install:android": "npm run install:android -w @lotto/mobile",
    "test": "npm run test -w @lotto/api && npm run test -w @lotto/web && npm run test -w @lotto/mobile",
    "build": "npm run build -w @lotto/web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3"
  }
}
